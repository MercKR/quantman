# 퀀트 플랫폼 서버 — 프로덕션 환경변수 예시
# 호스팅(Railway 등) 대시보드에서 아래 값을 설정한다.

# 길고 무작위한 비밀키 (JWT 서명). 예: python -c "import secrets;print(secrets.token_urlsafe(48))"
QP_SECRET_KEY=change-this-to-a-long-random-secret

# PostgreSQL 연결 (Neon 등에서 발급). 미설정 시 SQLite 사용(개발용).
QP_DB_URL=postgresql+psycopg://USER:PASSWORD@HOST/DBNAME

# 웹 SPA 도메인 — CORS 허용 + 페어링 안내 URL
QP_CORS_ORIGINS=https://your-web-app.vercel.app
QP_WEB_URL=https://your-web-app.vercel.app

# 액세스 토큰 유효시간(시간) — 선택
QP_ACCESS_TOKEN_HOURS=168

# Google 소셜 로그인 — Google Cloud Console에서 발급한 OAuth 2.0 클라이언트 ID.
# 미설정 시 Google 로그인 비활성(이메일/비밀번호 로그인만 동작).
QP_GOOGLE_CLIENT_ID=000000000000-xxxxxxxxxxxxxxxx.apps.googleusercontent.com

# 자연어→전략(NL→IR) 컴파일러 — Anthropic API 키. https://console.anthropic.com/ 에서 발급.
# 미설정 시 /ir/compile만 비활성(다른 기능엔 영향 없음).
ANTHROPIC_API_KEY=sk-ant-...
# (선택) 컴파일에 쓸 모델. 기본 claude-haiku-4-5-20251001 — Sonnet의 ⅓ 가격($1/$5).
# 관용구 쿡북 + 검증 피드백 안전망으로 archetype 평가에서 Sonnet과 동급. 더 어려운 입력엔
# claude-sonnet-4-6 등으로 교체 가능. 날짜 박힌 id는 고정 스냅샷(pinned)이라 프로덕션 안정.
QP_NL_COMPILE_MODEL=claude-haiku-4-5-20251001
